{
  "name": "agent-quorum",
  "version": "0.0.1",
  "description": "Iterative plan → critique → update orchestrator driving the Codex, Claude Code, and Cursor Agent CLIs",
  "license": "MIT",
  "author": "Aleksei Filippov <sensiloles@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sensiloles/agent-quorum.git"
  },
  "keywords": [
    "plan",
    "orchestrator",
    "llm",
    "codex",
    "claude",
    "cursor",
    "cli"
  ],
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.5.3",
  "bin": {
    "plan-loop": "dist/cli/main.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "skills",
    "plan-loop.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format-check": "prettier --check .",
    "test": "vitest run --coverage",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format-check && pnpm run test"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "diff": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
